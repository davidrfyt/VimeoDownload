{
    "name": "vimeo-downloader",
    "version": "1.0.0",
    "description": "Vimeo Downloader Pro - Professional Desktop Application",
    "author": {
        "name": "David",
        "email": "david@example.com"
    },
    "homepage": "https://github.com/DAVID/VimeoDownload",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DAVID/VimeoDownload.git"
    },
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder",
        "server": "node server.js"
