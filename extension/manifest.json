{
    "manifest_version": 3,
    "name": "Vimeo Downloader Pro",
    "version": "1.0",
    "description": "Descarga videos de Vimeo (requiere servidor local)",
    "permissions": [
        "tabs",
        "activeTab"
    ],
    "host_permissions": [
        "http://localhost:3000/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}